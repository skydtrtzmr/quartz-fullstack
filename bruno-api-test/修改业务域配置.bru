meta {
  name: 修改业务域配置
  type: http
  seq: 8
}

put {
  url: 127.0.0.1:8766/api/domain/xm2?user=admin&pwd=password123
  body: json
  auth: inherit
}

params:query {
  user: admin
  pwd: password123
}

body:json {
  {
    "layout": {
      "backlinks": {
        "hideWhenEmpty": false,
        "sort": {
          "type": "natural",
          "order": "desc",
          "field": ""
        },
        "aggregation": {
          "folder": { "depth": 2, "flatten": true },
          "fields": [
            { "field": "date", "granularity": "year", "order": 1 },
            { "field": "date", "granularity": "month", "order": 2 }
          ]
        }
      }
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: example1
  
  request: {
    url: 127.0.0.1:8766/api/domain/xm2?user=admin&pwd=password123
    method: PUT
    mode: json
    params:query: {
      user: admin
      pwd: password123
    }
  
    body:json: {
      {
        "config": {
          "pageTitle": "我的项目知识库",
          "graph": {
