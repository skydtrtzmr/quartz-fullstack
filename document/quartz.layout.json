{
  "explorer": {
    "sort": {
      "type": "natural",
      "order": "asc",
      "field": "title"
    }
  },
  "folderPage": {
    "sort": {
      "type": "date",
      "order": "desc",
      "field": "date"
    }
  },
  "backlinks": {
    "hideWhenEmpty": false,
    "sort": {
      "type": "date",
      "order": "desc",
      "field": "date"
    },
    "aggregation": [
      { "type": "folder", "depth": 1 },
      { "type": "date", "field": "date", "granularity": "year" },
      { "type": "field", "field": "type" }
    ]
  },
  "graph": {
    "aggregation": [
      { "type": "folder", "depth": 1 },
      { "type": "field", "field": "tags" },
      { "type": "field", "field": "type" }
    ]
  }
}
